# Digital Employability Platform - Environment Variables

# Server Configuration
NODE_ENV=development
PORT=5000

# MongoDB Connection
# Replace with your MongoDB connection string
# For local MongoDB: mongodb://localhost:27017/digital-employability
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/digital-employability
MONGODB_URI=mongodb://localhost:27017/digital-employability

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# CORS Configuration (optional)
# FRONTEND_URL=http://localhost:5173
